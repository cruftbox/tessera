# PlatformIO
.pio

# Editor — VS Code config is per-machine (contains local toolchain paths)
.vscode/

# Secrets — per-user credentials written by the setup wizard; never commit.
include/secrets.h

# Per-user device layout (entities/tiles); commit config.h.example as the template.
include/config.h

# Icon-font tooling (node deps)
tools/node_modules

# Python bytecode (setup_wizard.py / serial_read.py)
__pycache__/

# Firmware backups / binaries
*.bin

# Design prompts — not for the repo
tessera-prompt.md
*ESP32 Smart.md

# Local Claude project notes (contain personal/host details) — not for the repo
CLAUDE.md
