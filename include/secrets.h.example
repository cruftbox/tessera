#pragma once

// secrets.h.example — template for per-device credentials.
//
// The setup wizard (setup_wizard.py) generates include/secrets.h for you.
// To fill it in by hand instead, copy this file to include/secrets.h and edit.
// secrets.h is GITIGNORED so your WiFi password and HA token are never committed.
//
// Everything secret or deployment-specific about *connecting* lives here; what the
// panel *displays* (entities, tiles, icons, pins) lives in config.h.

// WiFi
#define WIFI_SSID      "YOUR_WIFI_SSID"
#define WIFI_PASSWORD  "YOUR_WIFI_PASSWORD"

// Home Assistant
#define HA_HOST   "192.168.1.10"   // your HA host IP
#define HA_PORT   8123
#define HA_TOKEN  "YOUR_LONG_LIVED_ACCESS_TOKEN"   // HA profile -> Long-Lived Access Tokens

// Time
#define TZ_INFO    "PST8PDT,M3.2.0,M11.1.0"   // POSIX TZ string for your zone
#define NTP_SERVER "pool.ntp.org"
